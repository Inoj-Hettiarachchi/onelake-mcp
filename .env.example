# OneLake MCP — Environment Template
# Copy this file to .env and fill in your values.
# Find GUIDs in the Microsoft Fabric portal (app.fabric.microsoft.com).
# .env is git-ignored. This file (.env.example) is safe to commit.

# ── Azure / Entra ─────────────────────────────────────────────────────────────
# Found at: Azure Portal → Azure Active Directory → Overview → Tenant ID
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Workspace GUIDs ───────────────────────────────────────────────────────────
# Found in Fabric URL: app.fabric.microsoft.com/groups/<WORKSPACE_ID>/...
ONELAKE_WORKSPACE=dev
ONELAKE_WORKSPACE_DEV=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ONELAKE_WORKSPACE_TST=
ONELAKE_WORKSPACE_PRD=

# ── Lakehouse GUIDs ───────────────────────────────────────────────────────────
# Found in Fabric URL: .../lakehouses/<LAKEHOUSE_ID>?...
ONELAKE_LAKEHOUSE_LANDING=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ONELAKE_LAKEHOUSE_BASE=
ONELAKE_LAKEHOUSE_CURATED=

# ── Behaviour (non-secret) ────────────────────────────────────────────────────
DATA_PRIVACY_MODE=strict
TOKEN_CACHE_MAX_AGE_HOURS=24
SCHEMA_CACHE_TTL_SECONDS=3600
